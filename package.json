{
  "name": "suika-multiplayer",
  "version": "0.0.1",
  "description": "suikagame with multiplayer",
  "main": "index.js",
  "scripts": {
    "//start": "APP_PORT=3010 nodemon --ignore ./src index.js",
    "build": "npm run build:proto && tsc index.ts",
    "build:proto": "pbjs -t static-module -w es6 -p ./proto -o ./build/bundle_proto.js ./proto/**/*.proto && pbts -o ./build/bundle_proto.d.ts ./build/bundle_proto.js",
    "start": "node index.js",
    "start:dev": "APP_PORT=3000 node -r ts-node/register index.ts",
    "dev": "npm run build:proto && npm run start:dev",
    "format": "NODE_OPTIONS=--loader=ts-node/esm npx prettier --write .",
    "check": "NODE_OPTIONS=--loader=ts-node/esm npx prettier --check .",
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NovaSagittarii/suika-multiplayer.git"
  },
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/NovaSagittarii/suika-multiplayer/issues"
  },
  "homepage": "https://github.com/NovaSagittarii/suika-multiplayer#readme",
  "dependencies": {
    "@dimforge/rapier2d": "^0.11.2",
    "@types/long": "^5.0.0",
    "@types/node": "^20.9.0",
    "express": "^4.18.2",
    "nodemon": "^3.0.1",
    "pixi.js": "^7.3.2",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "vite-plugin-top-level-await": "^1.3.1",
    "vite-plugin-wasm": "^3.2.2"
  },
  "devDependencies": {
    "@pixi/react": "^7.1.1",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.1.1",
    "prettier": "^3.0.3",
    "protobufjs": "^7.2.5",
    "protobufjs-cli": "^1.1.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "ts-node": "^10.9.1",
    "ts-protoc-gen": "^0.15.0",
    "typescript": "^5.2.2",
    "vite": "^4.5.0",
    "vitest": "^0.34.6"
  }
}
